<odoo>
    <!-- AI Provider Views -->
    <record id="view_ai_provider_tree" model="ir.ui.view">
        <field name="name">ai.assistant.provider.tree</field>
        <field name="model">ai.assistant.provider</field>
        <field name="arch" type="xml">
            <tree string="AI Providers">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="provider_type"/>
                <field name="model"/>
                <field name="state" widget="badge" decoration-success="state == 'configured'" decoration-danger="state == 'error'"/>
                <field name="is_default" widget="boolean_toggle"/>
                <field name="active" widget="boolean_toggle"/>
            </tree>
        </field>
    </record>
    
    <record id="view_ai_provider_form" model="ir.ui.view">
        <field name="name">ai.assistant.provider.form</field>
        <field name="model">ai.assistant.provider</field>
        <field name="arch" type="xml">
            <form string="AI Provider">
                <header>
                    <button name="action_test_connection" string="Test Connection" type="object" class="btn-primary" icon="fa-plug"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,configured,error"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="toggle_active" type="object" class="oe_stat_button" icon="fa-archive">
                            <field name="active" widget="boolean_button" options='{"terminology": "archive"}'/>
                        </button>
                    </div>
                    <widget name="web_ribbon" title="Archived" bg_color="bg-danger" attrs="{'invisible': [('active', '=', True)]}"/>
                    <div class="oe_title">
                        <label for="name" class="oe_edit_only"/>
                        <h1><field name="name" placeholder="e.g., OpenAI Production"/></h1>
                    </div>
                    <group>
                        <group string="Provider Settings">
                            <field name="provider_type"/>
                            <field name="model" placeholder="e.g., gpt-4o-mini, llama3.2"/>
                            <field name="is_default"/>
                        </group>
                        <group string="API Configuration">
                            <field name="api_key" password="True" attrs="{'invisible': [('provider_type', '=', 'ollama')]}"/>
                            <field name="base_url" attrs="{'invisible': [('provider_type', 'not in', ('ollama', 'google', 'custom'))]}" placeholder="http://localhost:11434 for Ollama or leave default"/>
                        </group>
                    </group>
                    <group string="Generation Settings">
                        <group>
                            <field name="temperature"/>
                            <field name="max_tokens"/>
                        </group>
                        <group>
                            <field name="requests_per_minute"/>
                        </group>
                    </group>
                    <group string="Connection Status" attrs="{'invisible': [('last_connection_test', '=', False)]}">
                        <field name="last_connection_test" readonly="1"/>
                        <field name="connection_message" readonly="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
    
    <record id="action_ai_provider" model="ir.actions.act_window">
        <field name="name">AI Providers</field>
        <field name="res_model">ai.assistant.provider</field>
        <field name="view_mode">tree,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Add your first AI provider
            </p>
            <p>
                Configure AI providers like OpenAI, Google Gemini, Ollama (local), or Anthropic Claude
                to enable AI-powered features in Odoo.
            </p>
        </field>
    </record>
</odoo>
