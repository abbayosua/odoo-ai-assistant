<?xml version="1.0" encoding="utf-8"?>
<!-- Part of Odoo AI Assistant. See LICENSE file for full copyright and licensing details. -->
<odoo noupdate="0">
    <!-- Demo AI Provider (Google Gemini) -->
    <record id="demo_provider_gemini" model="ai.assistant.provider">
        <field name="name">Google Gemini</field>
        <field name="provider_type">google</field>
        <field name="model">gemini-2.5-flash-lite</field>
        <field name="temperature">0.7</field>
        <field name="max_tokens">2000</field>
        <field name="is_default" eval="True"/>
        <field name="sequence">1</field>
    </record>
    
    <!-- Demo AI Provider (Ollama Local - for testing) -->
    <record id="demo_provider_ollama" model="ai.assistant.provider">
        <field name="name">Demo Ollama (Local)</field>
        <field name="provider_type">ollama</field>
        <field name="base_url">http://localhost:11434</field>
        <field name="model">llama3.2</field>
        <field name="temperature">0.7</field>
        <field name="max_tokens">2000</field>
        <field name="is_default" eval="False"/>
        <field name="sequence">10</field>
    </record>
    
    <!-- Demo AI Provider (OpenAI) -->
    <record id="demo_provider_openai" model="ai.assistant.provider">
        <field name="name">OpenAI</field>
        <field name="provider_type">openai</field>
        <field name="model">gpt-4o-mini</field>
        <field name="temperature">0.7</field>
        <field name="max_tokens">2000</field>
        <field name="is_default" eval="False"/>
        <field name="sequence">2</field>
    </record>
    
    <!-- Demo AI Provider (Anthropic) -->
    <record id="demo_provider_anthropic" model="ai.assistant.provider">
        <field name="name">Anthropic Claude</field>
        <field name="provider_type">anthropic</field>
        <field name="model">claude-3-haiku-20240307</field>
        <field name="temperature">0.7</field>
        <field name="max_tokens">2000</field>
        <field name="is_default" eval="False"/>
        <field name="sequence">3</field>
    </record>
    
    <!-- Demo Conversation -->
    <record id="demo_conversation_1" model="ai.assistant.conversation">
        <field name="title">Getting Started with AI Assistant</field>
        <field name="user_id" ref="base.user_admin"/>
    </record>
    
    <!-- Demo Messages -->
    <record id="demo_message_1" model="ai.assistant.message">
        <field name="conversation_id" ref="demo_conversation_1"/>
        <field name="role">user</field>
        <field name="content">Hello! Can you help me understand what this AI Assistant can do?</field>
    </record>
    
    <record id="demo_message_2" model="ai.assistant.message">
        <field name="conversation_id" ref="demo_conversation_1"/>
        <field name="role">assistant</field>
        <field name="content">Hello! I'm your AI Assistant integrated with Odoo. Here's what I can help you with:

1. **Answer Questions**: Ask me anything about your business data or Odoo features
2. **Generate Content**: I can help write emails, product descriptions, reports, and more
3. **Document Processing**: Upload documents and I'll extract the data for you
4. **Translations**: I can translate text between multiple languages
5. **Summaries**: I can summarize long documents or conversations

Just type your question or request, and I'll do my best to help!</field>
    </record>
    
    <!-- Demo Document -->
    <record id="demo_document_1" model="ai.assistant.document">
        <field name="filename">sample_invoice.pdf</field>
        <field name="document_type">invoice</field>
        <field name="target_model">account.move</field>
        <field name="state">draft</field>
        <field name="user_id" ref="base.user_admin"/>
    </record>
</odoo>
